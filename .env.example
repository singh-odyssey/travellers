# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/travellers

# NextAuth (v5 uses AUTH_SECRET; keep NEXTAUTH_SECRET for backward compat)
AUTH_SECRET="your secret"
NEXTAUTH_SECRET=" your secret "

NEXTAUTH_URL="http://localhost:3000"

# Google Maps API Key
# Get your API key from: https://console.cloud.google.com/google/maps-apis
# 
# REQUIRED APIs (Enable these in Google Cloud Console):
# 1. Maps JavaScript API
# 2. Places API (NEW - Required for address search)
# 3. Directions API
#
# Setup Instructions:
# 1. Go to https://console.cloud.google.com/
# 2. Create a new project or select existing
# 3. Enable the APIs listed above
# 4. Go to Credentials → Create Credentials → API Key
# 5. (Recommended) Add restrictions:
#    - Application restrictions: HTTP referrers
#    - Add: localhost:3000, yourdomain.com
#
NEXT_PUBLIC_MAP_STYLE=https://tiles.openfreemap.org/styles/liberty
NEXT_PUBLIC_OSRM_URL=https://router.project-osrm.org
NEXT_PUBLIC_NOMINATIM_URL=https://nominatim.openstreetmap.org


GEMINI_API_KEY="replace with api"
RESEND_API_KEY="replace-me" # Resend API Key for sending emails (https://resend.com)

GOOGLE_CLIENT_ID = 
GOOGLE_CLIENT_SECRET= 

APPLE_CLIENT_ID=
APPLE_CLEINT_SECRET=